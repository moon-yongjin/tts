#!/bin/bash

# [나노바나나 다운로드 파일 이름 정리기 실행]
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON_EXE="/usr/bin/python3"

echo "--------------------------------------------------"
echo "🍌 나노바나나(NB2) 다운로드 파일 이름 정리 시작"
echo "👉 파일명의 _1, _2 접미사를 제거하고 넘버링을 정리합니다."
echo "--------------------------------------------------"

cd "$PROJECT_DIR"

# 파이썬 실행
"$PYTHON_EXE" "google_flow_pro/nb2_rename.py"

echo ""
echo "--------------------------------------------------"
echo "✅ 작업이 완료되었습니다."
echo "--------------------------------------------------"
read -p "엔터를 누르면 종료됩니다."
