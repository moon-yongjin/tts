{
    "manifest_version": 3,
    "name": "Whisk Remote Stub",
    "version": "2.0",
    "description": "Remote control client for Whisk Auto Gen",
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "downloads"
    ],
    "host_permissions": [
        "https://labs.google/whisk/*",
        "https://labs.google/fx/tools/whisk/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://labs.google/whisk/*",
                "https://labs.google/fx/tools/whisk/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}