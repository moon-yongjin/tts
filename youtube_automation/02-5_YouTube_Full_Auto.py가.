import os
import sys
import subprocess
import re
import json
import time
from pathlib import Path

# [설정]
PYTHON_EXE = sys.executable
EXTRACTOR_SCRIPT = "extract_assets.py"
DOWNLOADS_DIR = Path.home() / "Downloads"

def run_command(cmd, description=None):
    if description:
        print(f"🚀 {description} 중...")
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return result.stdout
    except subprocess.CalledProcessError as e:
        print(f"❌ 에러 발생: {e.stderr}")
        return None

def get_video_metadata(url):
    print("🔍 영상 정보를 분석하는 중...")
    # 제목과 설명 추출
    cmd = ["yt-dlp", "--get-title", "--get-description", "--skip-download", url]
    output = run_command(cmd)
    if not output: return None, []
    
    lines = output.split('\n')
    title = lines[0].strip()
    description = '\n'.join(lines[1:])
    
    # 타임스탬프 추출 (00:00 사연명 또는 01:23:45 사연명)
    # 패턴: (시간) (공백/기호) (설명)
    ts_pattern = re.compile(r'(\d{1,2}:\d{2}(?::\d{2})?)\s*(?:[-:.\s])\s*(.+)')
    timestamps = ts_pattern.findall(description)
    
    # 중복 제거 및 시간순 정렬 (이미 되어있겠지만)
    unique_ts = []
    seen_times = set()
    for ts, name in timestamps:
        if ts not in seen_times:
            unique_ts.append((ts, name.strip()))
            seen_times.add(ts)
            
    return title, unique_ts

def download_full_video(url, title):
    safe_title = re.sub(r'[^\w\s-]', '', title).strip().replace(' ', '_')
    output_path = DOWNLOADS_DIR / f"{safe_title}_full.mp4"
    
    print(f"📥 전체 영상 다운로드 시작: {title}")
    cmd = [
        "yt-dlp",
        "-f", "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best",
        "-o", str(output_path),
        url
    ]
    subprocess.run(cmd)
    return output_path

def split_video(full_path, timestamps):
    video_name = full_path.stem.replace('_full', '')
    split_dir = DOWNLOADS_DIR / f"{video_name}_clips"
    split_dir.mkdir(parents=True, exist_ok=True)
    
    clips = []
    print(f"✂️ 총 {len(timestamps)}개의 구간으로 분할을 시작합니다...")
    
    for i in range(len(timestamps)):
        start_time = timestamps[i][0]
        # 다음 타임스탬프가 있으면 거기까지, 없으면 끝까지
        end_time = timestamps[i+1][0] if i + 1 < len(timestamps) else None
        
        clip_name = re.sub(r'[^\w\s-]', '', timestamps[i][1]).strip().replace(' ', '_')
        output_filename = f"{i+1:02d}_{clip_name}.mp4"
        output_path = split_dir / output_filename
        
        # ffmpeg를 사용한 무손실 분할
        cmd = ["ffmpeg", "-y", "-ss", start_time]
        if end_time:
            cmd += ["-to", end_time]
        
        # -c copy는 빠르지만 키프레임 문제로 정확도가 떨어질 수 있음
        # 하지만 사연 모음 분할에는 보통 충분함. 정확도를 원하면 인코딩(-c:v libx264) 사용.
        cmd += ["-i", str(full_path), "-c", "copy", "-avoid_negative_ts", "1", str(output_path)]
        
        print(f"   [{i+1}/{len(timestamps)}] 분할 중: {output_filename}")
        subprocess.run(cmd, capture_output=True)
        clips.append(output_path)
    
    return clips

def main():
    print("==========================================")
    print("📺 유튜브 전체 다운로드 & 자동 구간 분할")
    print("==========================================")
    
    url = input("🔗 유튜브 URL을 입력하세요: ").strip()
    if not url: return

    title, timestamps = get_video_metadata(url)
    if not title:
        print("❌ 영상 정보를 가져올 수 없습니다.")
        return

    # 1. 전체 영상 다운로드
    full_path = download_full_video(url, title)
    if not full_path.exists():
        print("❌ 다운로드 실패")
        return

    # 2. 구간 분할
    if not timestamps:
        print("ℹ️ 타임스탬프를 찾을 수 없어 분할을 스킵합니다.")
        return

    clips = split_video(full_path, timestamps)
    
    # 3. 각 클립별 에셋 추출
    print(f"\n🎙️ 추출된 {len(clips)}개 클립의 에셋(음성/자막) 추출을 시작하시겠습니까?")
    choice = input("👉 진행하시겠습니까? (Y/n): ").strip().lower()
    
    if choice != 'n':
        for i, clip in enumerate(clips):
            print(f"\n🚀 [{i+1}/{len(clips)}] 에셋 추출 중: {clip.name}")
            subprocess.run([PYTHON_EXE, EXTRACTOR_SCRIPT, str(clip)])

    print("\n" + "="*40)
    print("✨ 모든 작업이 완료되었습니다!")
    print(f"📂 결과물 확인: {full_path.parent}")
    print("="*40)
    
    os.system(f"open {full_path.parent}")

if __name__ == "__main__":
    main()
