verify_pkg/

# Media and binary files
*.mp4
*.wav
*.webm
*.part
*.exe
*.png
*.tar.gz
*.ckpt
*.safetensors
*.bin
*.pth

# Generated/temp directories
tmp_separated/
scrap/

# Data and asset directories
voices/
references/
reference_shorts/

# Web app dependencies (redundant but safe)
**/node_modules/
**/dist/
**/build/
