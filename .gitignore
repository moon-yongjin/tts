# Ignore all .env files everywhere
**/.env
**/.env.*
.env
.env.*

# Standard ignores
node_modules/
.DS_Store
__pycache__/
*.pyc
venv/
.venv/

# Large models and tool directories
kohya_ss/
Qwen3-TTS-finetune/
qwen3-tts-apple-silicon/
ComfyUI/
