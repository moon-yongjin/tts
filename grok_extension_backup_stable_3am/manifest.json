{
  "manifest_version": 3,
  "name": "Grok Bulk Premium v6",
  "version": "6.0.0",
  "description": "Professional Bulk Image-to-Video Production Suite",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": [
    "https://grok.com/*",
    "http://localhost:8000/*"
  ],
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "action": {
    "default_title": "Open Grok Bulk Control"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["https://grok.com/*"]
    }
  ]
}