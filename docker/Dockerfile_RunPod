# Dockerfile_RunPod
# Custom ComfyUI image for RunPod GGUF Generation

# PyTorch 2.4 + CUDA 12.4 base (required by latest ComfyUI)
FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

# Maintainer info
LABEL maintainer="tts_project"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    COMFY_DIR="/workspace/ComfyUI"

# Update apt and install required system tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    wget \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Note: PyTorch 2.4 + CUDA 12.4 is already in the base image.
# We only need to install ComfyUI's specific Python dependencies.

# Clone ComfyUI and Manager temporarily to install their exact requirements
RUN git clone https://github.com/comfyanonymous/ComfyUI.git /tmp/ComfyUI && \
    pip install --no-cache-dir -r /tmp/ComfyUI/requirements.txt && \
    rm -rf /tmp/ComfyUI

RUN git clone https://github.com/ltdrdata/ComfyUI-Manager.git /tmp/ComfyUI-Manager && \
    pip install --no-cache-dir -r /tmp/ComfyUI-Manager/requirements.txt && \
    rm -rf /tmp/ComfyUI-Manager

# Pre-install specific libraries for custom nodes and edge cases
RUN pip install --no-cache-dir \
    sqlalchemy \
    alembic \
    aiohttp \
    gguf \
    sentencepiece \
    protobuf \
    transformers \
    accelerate \
    safetensors \
    onnxruntime \
    websocket-client \
    einops \
    comfy-aimdo \
    comfy-kitchen \
    numpy --upgrade
# Add the entrypoint script
# Note: We copy the entrypoint script to the container root
# because /workspace might be overwritten by RunPod's volume mount
COPY comfy_entrypoint.sh /comfy_entrypoint.sh
RUN chmod +x /comfy_entrypoint.sh

# Set the entrypoint to the script
CMD ["/comfy_entrypoint.sh"]
