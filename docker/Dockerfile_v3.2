# Dockerfile_v3.2
# Optimized for RunPod (RTX 4090/5090)
# Bakes models and nodes into the image to eliminate startup delay (10min -> <1min)

FROM runpod/comfyui:latest-5090

LABEL maintainer="yong43285"

# 1. Install System Dependencies & HuggingFace CLI
RUN apt-get update && apt-get install -y wget git-lfs && \
    pip install --no-cache-dir huggingface_hub[cli]

# Ensure pip installed binaries are in PATH
ENV PATH="${PATH}:/root/.local/bin"

RUN pip install --no-cache-dir \
    gguf sqlalchemy alembic aiohttp sentencepiece protobuf \
    transformers accelerate safetensors onnxruntime websocket-client \
    einops numpy --upgrade

# 2. Pre-install Custom Nodes (Baking Nodes)
WORKDIR /workspace/ComfyUI/custom_nodes
RUN git clone https://github.com/city96/ComfyUI-GGUF && \
    git clone https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite && \
    git clone https://github.com/kijai/ComfyUI-WanVideoWrapper && \
    git clone https://github.com/ltdrdata/ComfyUI-Manager

# Install Node Requirements
RUN cd ComfyUI-VideoHelperSuite && pip install -r requirements.txt && \
    cd ../ComfyUI-WanVideoWrapper && pip install -r requirements.txt

# 3. Bake Models (Python-based download for maximum reliability)
RUN python3 -c 'from huggingface_hub import hf_hub_download; \
    hf_hub_download(repo_id="Comfy-Org/z_image_turbo", filename="split_files/diffusion_models/z_image_turbo_bf16.safetensors", local_dir="/workspace/ComfyUI/models/diffusion_models"); \
    hf_hub_download(repo_id="Comfy-Org/z_image_turbo", filename="split_files/text_encoders/qwen_3_4b.safetensors", local_dir="/workspace/ComfyUI/models/clip"); \
    hf_hub_download(repo_id="Comfy-Org/z_image_turbo", filename="split_files/vae/ae.safetensors", local_dir="/workspace/ComfyUI/models/vae"); \
    hf_hub_download(repo_id="Comfy-Org/Lumina_Image_2.0_Repackaged", filename="all_in_one/lumina_2.safetensors", local_dir="/workspace/ComfyUI/models/checkpoints", local_dir_use_symlinks=False)' && \
    mv /workspace/ComfyUI/models/diffusion_models/split_files/diffusion_models/z_image_turbo_bf16.safetensors /workspace/ComfyUI/models/diffusion_models/z_image_turbo_bf16.safetensors && \
    mv /workspace/ComfyUI/models/clip/split_files/text_encoders/qwen_3_4b.safetensors /workspace/ComfyUI/models/clip/qwen_3_4b.safetensors && \
    mv /workspace/ComfyUI/models/vae/split_files/vae/ae.safetensors /workspace/ComfyUI/models/vae/ae.safetensors && \
    mv /workspace/ComfyUI/models/checkpoints/all_in_one/lumina_2.safetensors /workspace/ComfyUI/models/checkpoints/lumina_2.safetensors && \
    rm -rf /workspace/ComfyUI/models/diffusion_models/split_files /workspace/ComfyUI/models/clip/split_files /workspace/ComfyUI/models/vae/split_files /workspace/ComfyUI/models/checkpoints/all_in_one

# 4. Final Setup
WORKDIR /workspace/ComfyUI
COPY comfy_entrypoint_v3.2.sh /comfy_entrypoint.sh
RUN chmod +x /comfy_entrypoint.sh

EXPOSE 8188

CMD ["/comfy_entrypoint.sh"]
